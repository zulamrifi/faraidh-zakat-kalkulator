<script>
// ===================================================
// NAVIGATION
// ===================================================
function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  event.target.classList.add('active');
}

// ===================================================
// UTILITY
// ===================================================
function fmt(n) {
  return 'Rp ' + Math.round(n).toLocaleString('id-ID');
}
function fmtFraksi(n, d) {
  if (n === 0) return '0';
  const gcd = (a,b) => b ? gcd(b, a%b) : a;
  const g = gcd(n, d);
  return n/g + '/' + d/g;
}
function getVal(id) { return parseFloat(document.getElementById(id).value) || 0; }
function getChk(id) { return document.getElementById(id).checked; }

// ===================================================
// FARAIDH ENGINE
// ===================================================
function hitungWaris() {
  const totalHarta = getVal('total-harta');
  if (!totalHarta || totalHarta <= 0) {
    alert('Masukkan jumlah harta warisan terlebih dahulu.');
    return;
  }

  const hutang = getVal('hutang');
  const wasiat = getVal('wasiat');
  const pemakaman = getVal('biaya-pemakaman');
  const jenisMayyit = document.getElementById('jenis-mayyit').value;

  // Harta bersih
  const hartaBersih = Math.max(0, totalHarta - pemakaman - hutang);
  const batasWasiat = hartaBersih / 3;
  const wasiatEfektif = Math.min(wasiat, batasWasiat);
  const hartaDibagi = Math.max(0, hartaBersih - wasiatEfektif);

  // Ahli waris input
  const adaSuami = getChk('suami') && jenisMayyit === 'perempuan';
  // UPDATE: Tangkap value dari select dropdown Istri
  const jumlahIstri = getVal('istri'); 
  const adaIstri = jumlahIstri > 0 && jenisMayyit === 'laki';
  
  const anakLaki = getVal('anak-laki');
  const anakPerempuan = getVal('anak-perempuan');
  const adaAyah = getChk('ayah');
  const adaIbu = getChk('ibu');
  const sdrLaki = getVal('sdr-laki');
  const sdrPerempuan = getVal('sdr-perempuan');
  const cucuLaki = getVal('cucu-laki');
  const cucuPerempuan = getVal('cucu-perempuan');
  const adaKakek = getChk('kakek');
  const adaNenek = getChk('nenek');
  const sdrLakiAyah = getVal('sdr-laki-ayah');
  const sdrPerempuanAyah = getVal('sdr-perempuan-ayah');

  const adaAnakLaki = anakLaki > 0;
  const adaAnakPerempuan = anakPerempuan > 0;
  const adaAnak = adaAnakLaki || adaAnakPerempuan;
  const adaCucuLaki = cucuLaki > 0;
  const adaCucuPerempuan = cucuPerempuan > 0;
  const adaCucu = adaCucuLaki || adaCucuPerempuan;
  const adaSdrLaki = sdrLaki > 0;
  const adaSdrPerempuan = sdrPerempuan > 0;
  const adaSdr = adaSdrLaki || adaSdrPerempuan;

  let ahliWaris = []; // {nama, bagian_penyebut [num,den], nominal, hajb, alasan_hajb, jenis}
  let penjelasan = [];
  let aul = false, radd = false, ummariyatayn = false;

  // Hijab rules
  const hajbSdrOlehAnak = adaAnakLaki || adaCucuLaki || adaAyah;
  const hajbCucuOlehAnakLaki = adaAnakLaki;
  const hajbKakekOlehAyah = adaAyah;
  const hajbNenekOlehIbu = adaIbu;
  const hajbSdrAyahOlehSdrKandung = adaSdrLaki || adaAnakLaki || adaAyah || adaCucuLaki;

  let ahli = [];

  // SUAMI
  if (adaSuami) {
    let fardh, alasan;
    if (adaAnak || adaCucu) { fardh = [1,4]; alasan = 'Suami mendapat 1/4 karena pewaris meninggalkan anak/cucu.'; }
    else { fardh = [1,2]; alasan = 'Suami mendapat 1/2 karena tidak ada anak/cucu.'; }
    ahli.push({id:'suami', nama:'Suami', jumlah:1, hajb:false, alasan_hajb:'', fardh, ashobah:false, alasan});
  }
  // ISTRI (UPDATE: Logika jika istri lebih dari 1)
  if (adaIstri) {
    let fardh, alasan;
    if (adaAnak || adaCucu) { fardh = [1,8]; alasan = jumlahIstri > 1 ? `Istri (${jumlahIstri} org) berbagi 1/8 karena pewaris meninggalkan anak/cucu.` : 'Istri mendapat 1/8 karena pewaris meninggalkan anak/cucu.'; }
    else { fardh = [1,4]; alasan = jumlahIstri > 1 ? `Istri (${jumlahIstri} org) berbagi 1/4 karena tidak ada anak/cucu.` : 'Istri mendapat 1/4 karena tidak ada anak/cucu.'; }
    ahli.push({id:'istri', nama:'Istri', jumlah:jumlahIstri, hajb:false, alasan_hajb:'', fardh, ashobah:false, alasan});
  }
  // ANAK LAKI-LAKI
  if (adaAnakLaki) {
    ahli.push({id:'anak-laki', nama:'Anak Laki-laki', jumlah:anakLaki, hajb:false, alasan_hajb:'', fardh:null, ashobah:true, alasan:'Anak laki-laki adalah ashobah binafsi, mewarisi sisa harta setelah ashabul furudh.'});
  }
  // ANAK PEREMPUAN
  if (adaAnakPerempuan) {
    if (adaAnakLaki) {
      ahli.push({id:'anak-perempuan', nama:'Anak Perempuan', jumlah:anakPerempuan, hajb:false, alasan_hajb:'', fardh:null, ashobah:true, ashobahBersama:'anak-laki', alasan:'Anak perempuan menjadi ashobah bil ghair (bersama anak laki-laki) dengan bagian 1:2.'});
    } else {
      let fardh, alasan;
      if (anakPerempuan === 1) { fardh = [1,2]; alasan = 'Anak perempuan tunggal mendapat 1/2.'; }
      else { fardh = [2,3]; alasan = `${anakPerempuan} anak perempuan (tanpa anak laki) mendapat 2/3 dibagi rata.`; }
      ahli.push({id:'anak-perempuan', nama:'Anak Perempuan', jumlah:anakPerempuan, hajb:false, alasan_hajb:'', fardh, ashobah:false, alasan});
    }
  }
  // CUCU (dari anak laki)
  if (adaCucuLaki && !adaAnakLaki) {
    ahli.push({id:'cucu-laki', nama:'Cucu Laki-laki (dr Anak Laki)', jumlah:cucuLaki, hajb:hajbCucuOlehAnakLaki, alasan_hajb:'Terhijab oleh Anak Laki-laki', fardh:null, ashobah:true, alasan:'Cucu laki-laki menggantikan posisi anak laki-laki bila tidak ada.'});
  } else if (adaCucuLaki && hajbCucuOlehAnakLaki) {
    ahli.push({id:'cucu-laki', nama:'Cucu Laki-laki (dr Anak Laki)', jumlah:cucuLaki, hajb:true, alasan_hajb:'Terhijab oleh Anak Laki-laki', fardh:null, ashobah:false, alasan:''});
  }
  if (adaCucuPerempuan) {
    if (adaAnakLaki) {
      ahli.push({id:'cucu-perempuan', nama:'Cucu Perempuan (dr Anak Laki)', jumlah:cucuPerempuan, hajb:true, alasan_hajb:'Terhijab oleh Anak Laki-laki', fardh:null, ashobah:false, alasan:''});
    } else if (adaCucuLaki) {
      ahli.push({id:'cucu-perempuan', nama:'Cucu Perempuan (dr Anak Laki)', jumlah:cucuPerempuan, hajb:false, alasan_hajb:'', fardh:null, ashobah:true, ashobahBersama:'cucu-laki', alasan:'Cucu perempuan ashobah bil ghair bersama cucu laki.'});
    } else if (adaAnakPerempuan) {
      if (anakPerempuan === 1) {
        ahli.push({id:'cucu-perempuan', nama:'Cucu Perempuan (dr Anak Laki)', jumlah:cucuPerempuan, hajb:false, alasan_hajb:'', fardh:[1,6], ashobah:false, alasan:'Cucu perempuan mendapat 1/6 sebagai pelengkap 2/3 (bersama 1 anak perempuan yang mendapat 1/2).'});
      } else {
        ahli.push({id:'cucu-perempuan', nama:'Cucu Perempuan (dr Anak Laki)', jumlah:cucuPerempuan, hajb:true, alasan_hajb:'Terhijab karena anak perempuan sudah mencapai batas 2/3', fardh:null, ashobah:false, alasan:''});
      }
    } else {
      if (cucuPerempuan === 1) {
        ahli.push({id:'cucu-perempuan', nama:'Cucu Perempuan (dr Anak Laki)', jumlah:cucuPerempuan, hajb:false, alasan_hajb:'', fardh:[1,2], ashobah:false, alasan:'Cucu perempuan tunggal mendapat 1/2.'});
      } else {
        ahli.push({id:'cucu-perempuan', nama:'Cucu Perempuan (dr Anak Laki)', jumlah:cucuPerempuan, hajb:false, alasan_hajb:'', fardh:[2,3], ashobah:false, alasan:`${cucuPerempuan} cucu perempuan (tanpa anak laki/cucu laki) mendapat 2/3.`});
      }
    }
  }
  // AYAH
  if (adaAyah) {
    if (adaAnak || adaCucu) {
      ahli.push({id:'ayah', nama:'Ayah', jumlah:1, hajb:false, alasan_hajb:'', fardh:[1,6], ashobah:false, alasan:'Ayah mendapat 1/6 karena ada anak/cucu.'});
    } else {
      if (adaAnakPerempuan && !adaAnakLaki) {
        ahli.push({id:'ayah', nama:'Ayah', jumlah:1, hajb:false, alasan_hajb:'', fardh:[1,6], ashobah:true, alasan:'Ayah mendapat 1/6 (fardh) ditambah sisa harta (ashobah) karena ada anak perempuan tanpa anak laki.'});
      } else {
        ahli.push({id:'ayah', nama:'Ayah', jumlah:1, hajb:false, alasan_hajb:'', fardh:null, ashobah:true, alasan:'Ayah ashobah binafsi, mewarisi sisa harta setelah ashabul furudh karena tidak ada anak/cucu.'});
      }
    }
  }
  // IBU
  if (adaIbu) {
    let fardh, alasan;
    const banyakSdr = sdrLaki + sdrPerempuan + sdrLakiAyah + sdrPerempuanAyah;
    if (adaAnak || adaCucu || banyakSdr >= 2) {
      fardh = [1,6]; alasan = 'Ibu mendapat 1/6 karena ada anak/cucu atau 2+ saudara.';
    } else {
      fardh = [1,3]; alasan = 'Ibu mendapat 1/3 karena tidak ada anak/cucu dan saudara kurang dari 2.';
      if ((adaSuami || adaIstri) && adaAyah && !adaAnak && !adaCucu) {
        ummariyatayn = true;
      }
    }
    ahli.push({id:'ibu', nama:'Ibu', jumlah:1, hajb:false, alasan_hajb:'', fardh, ashobah:false, alasan});
  }
  // KAKEK
  if (adaKakek) {
    if (adaAyah) {
      ahli.push({id:'kakek', nama:'Kakek (dr Ayah)', jumlah:1, hajb:true, alasan_hajb:'Terhijab oleh Ayah', fardh:null, ashobah:false, alasan:''});
    } else {
      if (adaAnak || adaCucu) {
        ahli.push({id:'kakek', nama:'Kakek (dr Ayah)', jumlah:1, hajb:false, alasan_hajb:'', fardh:[1,6], ashobah:false, alasan:'Kakek mendapat 1/6 menggantikan posisi ayah karena ada anak/cucu.'});
      } else {
        if (adaAnakPerempuan && !adaAnakLaki) {
          ahli.push({id:'kakek', nama:'Kakek (dr Ayah)', jumlah:1, hajb:false, alasan_hajb:'', fardh:[1,6], ashobah:true, alasan:'Kakek mendapat 1/6 + sisa (menggantikan ayah).'});
        } else {
          ahli.push({id:'kakek', nama:'Kakek (dr Ayah)', jumlah:1, hajb:false, alasan_hajb:'', fardh:null, ashobah:true, alasan:'Kakek ashobah menggantikan ayah.'});
        }
      }
    }
  }
  // NENEK
  if (adaNenek) {
    if (adaIbu) {
      ahli.push({id:'nenek', nama:'Nenek (dr Ibu)', jumlah:1, hajb:true, alasan_hajb:'Terhijab oleh Ibu', fardh:null, ashobah:false, alasan:''});
    } else {
      ahli.push({id:'nenek', nama:'Nenek (dr Ibu)', jumlah:1, hajb:false, alasan_hajb:'', fardh:[1,6], ashobah:false, alasan:'Nenek mendapat 1/6 menggantikan posisi ibu.'});
    }
  }
  // SAUDARA KANDUNG
  const adaHijabSdr = adaAnakLaki || adaCucuLaki || adaAyah || (adaKakek && !adaAyah);
  if (adaSdrLaki) {
    if (adaHijabSdr) {
      ahli.push({id:'sdr-laki', nama:'Saudara Laki Kandung', jumlah:sdrLaki, hajb:true, alasan_hajb:'Terhijab oleh Anak Laki/Cucu Laki/Ayah/Kakek', fardh:null, ashobah:false, alasan:''});
    } else {
      ahli.push({id:'sdr-laki', nama:'Saudara Laki Kandung', jumlah:sdrLaki, hajb:false, alasan_hajb:'', fardh:null, ashobah:true, alasan:'Saudara laki kandung ashobah binafsi.'});
    }
  }
  if (adaSdrPerempuan) {
    if (adaHijabSdr) {
      ahli.push({id:'sdr-perempuan', nama:'Saudara Perempuan Kandung', jumlah:sdrPerempuan, hajb:true, alasan_hajb:'Terhijab oleh Anak Laki/Cucu Laki/Ayah/Kakek', fardh:null, ashobah:false, alasan:''});
    } else if (adaSdrLaki) {
      ahli.push({id:'sdr-perempuan', nama:'Saudara Perempuan Kandung', jumlah:sdrPerempuan, hajb:false, alasan_hajb:'', fardh:null, ashobah:true, ashobahBersama:'sdr-laki', alasan:'Saudara perempuan ashobah bil ghair bersama saudara laki kandung (1:2).'});
    } else if (adaAnakPerempuan || adaCucuPerempuan) {
      ahli.push({id:'sdr-perempuan', nama:'Saudara Perempuan Kandung', jumlah:sdrPerempuan, hajb:false, alasan_hajb:'', fardh:null, ashobah:true, alasan:'Saudara perempuan menjadi ashobah ma\'al ghair bersama anak/cucu perempuan.'});
    } else {
      let fardh, alasan2;
      if (sdrPerempuan === 1) { fardh = [1,2]; alasan2 = 'Saudara perempuan kandung tunggal mendapat 1/2.'; }
      else { fardh = [2,3]; alasan2 = `${sdrPerempuan} saudara perempuan kandung mendapat 2/3.`; }
      ahli.push({id:'sdr-perempuan', nama:'Saudara Perempuan Kandung', jumlah:sdrPerempuan, hajb:false, alasan_hajb:'', fardh, ashobah:false, alasan:alasan2});
    }
  }
  // SAUDARA SEAYAH
  const adaHijabSdrAyah = adaAnakLaki || adaCucuLaki || adaAyah || (adaKakek && !adaAyah) || adaSdrLaki || (adaSdrPerempuan && !adaAnakPerempuan && !adaCucuPerempuan);
  if (sdrLakiAyah > 0) {
    if (adaHijabSdrAyah) {
      ahli.push({id:'sdr-laki-ayah', nama:'Saudara Laki Seayah', jumlah:sdrLakiAyah, hajb:true, alasan_hajb:'Terhijab oleh Saudara Kandung/Anak Laki/Ayah', fardh:null, ashobah:false, alasan:''});
    } else {
      ahli.push({id:'sdr-laki-ayah', nama:'Saudara Laki Seayah', jumlah:sdrLakiAyah, hajb:false, alasan_hajb:'', fardh:null, ashobah:true, alasan:'Saudara laki seayah ashobah (bila tidak ada saudara kandung).'});
    }
  }
  if (sdrPerempuanAyah > 0) {
    if (adaHijabSdrAyah) {
      ahli.push({id:'sdr-perempuan-ayah', nama:'Saudara Perempuan Seayah', jumlah:sdrPerempuanAyah, hajb:true, alasan_hajb:'Terhijab oleh Saudara Kandung/Anak Laki/Ayah', fardh:null, ashobah:false, alasan:''});
    } else if (sdrLakiAyah > 0) {
      ahli.push({id:'sdr-perempuan-ayah', nama:'Saudara Perempuan Seayah', jumlah:sdrPerempuanAyah, hajb:false, alasan_hajb:'', fardh:null, ashobah:true, ashobahBersama:'sdr-laki-ayah', alasan:'Ashobah bil ghair bersama saudara laki seayah (1:2).'});
    } else {
      let fardh2;
      if (sdrPerempuanAyah === 1) fardh2 = [1,2]; else fardh2 = [2,3];
      ahli.push({id:'sdr-perempuan-ayah', nama:'Saudara Perempuan Seayah', jumlah:sdrPerempuanAyah, hajb:false, alasan_hajb:'', fardh:fardh2, ashobah:false, alasan:'Saudara perempuan seayah mendapat fardh.'});
    }
  }

  // ============ HITUNG NOMINAL ============
  let penyebutBersama = 1;
  let ahliAktif = ahli.filter(a => !a.hajb);
  
  function lcm(a, b) { return a * b / gcd(a, b); }
  function gcd(a, b) { return b ? gcd(b, a%b) : a; }
  
  let penyebuts = ahliAktif.filter(a => a.fardh).map(a => a.fardh[1]);
  if (penyebuts.length > 0) {
    penyebutBersama = penyebuts.reduce(lcm, 1);
  }

  ahliAktif.forEach(a => {
    if (a.fardh) {
      a.pembilangAsli = a.fardh[0] * (penyebutBersama / a.fardh[1]);
    } else {
      a.pembilangAsli = 0;
    }
  });

  let totalFardh = ahliAktif.filter(a=>a.fardh).reduce((s,a) => s + a.pembilangAsli, 0);
  let sisaUntukAshobah = penyebutBersama - totalFardh;

  let infoUmmariyatayn = '';
  if (ummariyatayn) {
    const ibuObj = ahliAktif.find(a => a.id === 'ibu');
    const ayahObj = ahliAktif.find(a => a.id === 'ayah');
    const pasanganObj = ahliAktif.find(a => a.id === 'suami' || a.id === 'istri');
    if (ibuObj && ayahObj && pasanganObj) {
      const bagianPasangan = pasanganObj.fardh ? pasanganObj.fardh[0] / pasanganObj.fardh[1] : 0;
      const sisaSetelahPasangan = 1 - bagianPasangan;
      const bagianIbu = sisaSetelahPasangan / 3;
      const bagianAyah = sisaSetelahPasangan * 2 / 3;
      ibuObj.fardh_override = bagianIbu;
      ayahObj.fardh_override = bagianAyah;
      ayahObj.ashobah = false;
      infoUmmariyatayn = `Kasus <strong>Ummariyatayn (Gharrawayn)</strong>: Ibu mendapat 1/3 dari sisa harta setelah bagian ${pasanganObj.nama}, yaitu 1/3 × ${((1 - bagianPasangan)*100).toFixed(0)}% = ${(bagianIbu*100).toFixed(2)}%. Ayah mendapat sisanya ${(bagianAyah*100).toFixed(2)}%.`;
    }
  }

  // UPDATE 5: Koreksi Unit Ashobah (2:1 untuk Anak/Cucu/Saudara)
  let ashobahList = ahliAktif.filter(a => a.ashobah && !a.ashobahBersama);
  let ashobahBersamaList = ahliAktif.filter(a => a.ashobah && a.ashobahBersama);
  
  let totalUnitAshobah = 0;
  ashobahList.forEach(a => {
    // Memastikan laki-laki (anak, cucu, dan SAUDARA laki) dihitung 2 unit
    if ['anak-laki', 'cucu-laki', 'sdr-laki', 'sdr-laki-ayah'].includes(a.id)) {
      totalUnitAshobah += a.jumlah * 2;
    } else {
      totalUnitAshobah += a.jumlah;
    }
  });
  ahliAktif.filter(a => a.ashobahBersama).forEach(a => {
    totalUnitAshobah += a.jumlah * 1; 
  });

  let hasilAhli = [];

  ahli.forEach(a => {
    let nominal = 0, fraksiStr = '';
    if (a.hajb) {
      hasilAhli.push({...a, nominal:0, fraksiStr:'Gugur (Mahjub)', bagianDesimal:0});
      return;
    }
    
    if (a.fardh_override !== undefined) {
      nominal = hartaDibagi * a.fardh_override;
      fraksiStr = (a.fardh_override * 100).toFixed(2) + '%';
    } else if (a.fardh) {
      const desimal = a.fardh[0] / a.fardh[1];
      nominal = hartaDibagi * desimal;
      if (a.jumlah > 1) {
        fraksiStr = fmtFraksi(a.fardh[0], a.fardh[1]) + ' (dibagi ' + a.jumlah + ')';
      } else {
        fraksiStr = fmtFraksi(a.fardh[0], a.fardh[1]);
      }
    } else if (a.ashobah) {
      if (sisaUntukAshobah <= 0 && !ummariyatayn) {
        fraksiStr = 'Ashobah (sisa)';
        nominal = 0;
      } else {
        let unit;
        // Koreksi unit individu ashobah
        if (['anak-laki', 'cucu-laki', 'sdr-laki', 'sdr-laki-ayah'].includes(a.id)) {
            unit = a.jumlah * 2;
        } else {
            unit = a.jumlah;
        }
        
        const sisaNominal = hartaDibagi * (sisaUntukAshobah / penyebutBersama);
        if (totalUnitAshobah > 0) {
          nominal = (sisaNominal * unit) / totalUnitAshobah;
          fraksiStr = 'Ashobah ' + unit + '/' + totalUnitAshobah + ' dari sisa';
        } else {
          nominal = sisaNominal;
          fraksiStr = 'Ashobah (semua sisa)';
        }
        if (a.id === 'ayah' && a.fardh) {
          const faradhAyah = hartaDibagi / 6;
          const sisaTotal = hartaDibagi * Math.max(0, (penyebutBersama - totalFardh) / penyebutBersama);
          nominal = faradhAyah + sisaTotal;
          fraksiStr = '1/6 + sisa harta';
        }
      }
    }

    if (a.ashobahBersama) {
      const pasangan = ahli.find(x => x.id === a.ashobahBersama);
      if (pasangan && !pasangan.hajb) {
        let unitLaki = pasangan.jumlah * 2;
        let unitPerempuan = a.jumlah;
        let unitTotal = unitLaki + unitPerempuan;
        const sisaNominal = hartaDibagi * (sisaUntukAshobah / penyebutBersama);
        nominal = (sisaNominal * unitPerempuan) / unitTotal;
        fraksiStr = 'Ashobah 1/' + (unitTotal/unitPerempuan).toFixed(1) + ' dari sisa';
      }
    }

    hasilAhli.push({...a, nominal, fraksiStr});
  });

  if (totalFardh > penyebutBersama) {
    aul = true;
    const faktor = penyebutBersama / totalFardh;
    hasilAhli.forEach(a => {
      if (!a.hajb && a.fardh) {
        a.nominal = hartaDibagi * (a.fardh[0] / a.fardh[1]) * faktor;
        a.fraksiStr += ' (dikurangi aul)';
      }
    });
  }

  const totalTerbagi = hasilAhli.reduce((s, a) => s + a.nominal, 0);
  const sisaRadd = hartaDibagi - totalTerbagi;
  if (!aul && sisaRadd > 1 && ashobahList.length === 0) {
    radd = true;
    const penerimRadd = hasilAhli.filter(a => !a.hajb && a.fardh && a.id !== 'suami' && a.id !== 'istri');
    const totalBagianRadd = penerimRadd.reduce((s,a) => s + (a.fardh ? a.fardh[0]/a.fardh[1] : 0), 0);
    penerimRadd.forEach(a => {
      const proporsi = (a.fardh[0]/a.fardh[1]) / totalBagianRadd;
      a.nominal += sisaRadd * proporsi;
      a.fraksiStr += ' + radd';
    });
  }

  // ============ RENDER ============
  document.getElementById('faraidh-result').style.display = 'block';
  document.getElementById('res-harta-bersih').textContent = fmt(hartaDibagi);
  
  let infoHartaArr = [];
  if (pemakaman > 0) infoHartaArr.push(`Biaya pemakaman: ${fmt(pemakaman)}`);
  if (hutang > 0) infoHartaArr.push(`Hutang: ${fmt(hutang)}`);
  if (wasiatEfektif > 0) infoHartaArr.push(`Wasiat: ${fmt(wasiatEfektif)}`);
  if (wasiat > batasWasiat && wasiat > 0) infoHartaArr.push(`⚠️ Wasiat melebihi 1/3, disesuaikan menjadi ${fmt(batasWasiat)}`);
  document.getElementById('res-info-harta').textContent = infoHartaArr.length ? infoHartaArr.join(' · ') : 'Harta bersih siap dibagikan';

  let specialHTML = '';
  if (aul) specialHTML += `<div class="info-box aul"><strong>⚠️ Kasus 'Aul (عَوْل)</strong>Total bagian fardh melebihi harta (penyebut bersama). Solusi: seluruh bagian dikurangi secara proporsional agar total = 100%.</div>`;
  if (radd) specialHTML += `<div class="info-box radd"><strong>↩️ Kasus Radd (رَدّ)</strong>Masih ada sisa harta setelah dibagikan dan tidak ada ashobah. Sisa dikembalikan kepada ashabul furudh (kecuali pasangan) secara proporsional.</div>`;
  if (ummariyatayn) specialHTML += `<div class="info-box ummariyatayn"><strong>📐 Kasus Ummariyatayn / Gharrawayn</strong>${infoUmmariyatayn}</div>`;
  document.getElementById('res-special-info').innerHTML = specialHTML;

  let gridHTML = '';
  hasilAhli.forEach(a => {
    const isHajb = a.hajb;
    const nomStr = isHajb ? '—' : fmt(a.nominal);
    const perOrg = (!isHajb && a.jumlah > 1) ? `<div class="ahli-alasan">Per orang: ${fmt(a.nominal / a.jumlah)}</div>` : '';
    gridHTML += `<div class="ahli-card ${isHajb ? 'hajb' : 'mendapat'}">
      <div class="ahli-name">${a.nama}${a.jumlah > 1 ? ' (×'+a.jumlah+')' : ''}</div>
      ${isHajb
        ? `<div class="ahli-status">GUGUR / MAHJUB</div><div class="ahli-alasan">${a.alasan_hajb}</div>`
        : `<div class="ahli-bagian">${a.fraksiStr}</div><div class="ahli-nominal">${nomStr}</div>${perOrg}`
      }
    </div>`;
  });
  document.getElementById('res-ahli-grid').innerHTML = gridHTML;

  renderFamilyTree(hasilAhli, jenisMayyit);

  let penjelasanHTML = `<p style="margin-bottom:12px;">Setelah dikurangi biaya pemakaman, hutang, dan wasiat, harta yang dibagikan adalah <strong>${fmt(hartaDibagi)}</strong>. Berikut rincian tiap ahli waris:</p><ul style="padding-left:20px;">`;
  hasilAhli.forEach(a => {
    if (a.hajb) {
      penjelasanHTML += `<li style="margin-bottom:6px;color:#906060;"><strong>${a.nama}</strong>: Terhijab (gugur hak warisnya) — ${a.alasan_hajb}.</li>`;
    } else if (a.alasan) {
      penjelasanHTML += `<li style="margin-bottom:6px;"><strong>${a.nama}</strong>: ${a.alasan} Bagian: ${fmt(a.nominal)}.</li>`;
    }
  });
  penjelasanHTML += '</ul>';
  if (aul) penjelasanHTML += `<p style="margin-top:12px;padding:12px;background:var(--gold-pale);border-radius:8px;font-size:13.5px;">📌 <strong>Catatan 'Aul:</strong> Terjadi karena jumlah bagian fardh melebihi 100%. Seluruh bagian dikurangi proporsional. Ini adalah pendapat mayoritas sahabat dan jumhur ulama (kecuali Ibnu Abbas).</p>`;
  if (radd) penjelasanHTML += `<p style="margin-top:12px;padding:12px;background:#e8f0ff;border-radius:8px;font-size:13.5px;">📌 <strong>Catatan Radd:</strong> Sisa harta dikembalikan ke ahli waris furudh (selain suami/istri) secara proporsional. Pendapat jumhur ulama menerima radd.</p>`;
  document.getElementById('res-penjelasan').innerHTML = penjelasanHTML;
  document.getElementById('faraidh-result').scrollIntoView({behavior:'smooth', block:'start'});
}

function renderFamilyTree(ahli, jenisMayyit) {
  const find = (id) => ahli.find(a => a.id === id);
  const box = (a) => {
    if (!a) return '';
    const cls = a.hajb ? 'hajb' : 'mendapat';
    const bagian = a.hajb ? 'GUGUR' : a.fraksiStr;
    return `<div class="tree-node">
      <div class="tree-node-box ${cls}">${a.nama}${a.jumlah>1?' (×'+a.jumlah+')':''}</div>
      <div class="${a.hajb ? 'tree-node-hajb-text' : 'tree-node-bagian'}">${bagian}</div>
    </div>`;
  };

  let html = '';
  const kakek = find('kakek'), nenek = find('nenek');
  if (kakek || nenek) {
    html += `<div class="tree-row">${kakek ? box(kakek) : ''}${nenek ? box(nenek) : ''}</div>`;
    html += `<div class="tree-connector">↓</div>`;
  }
  const ayah = find('ayah'), ibu = find('ibu');
  if (ayah || ibu) {
    html += `<div class="tree-row">${ayah ? box(ayah) : ''}${ibu ? box(ibu) : ''}</div>`;
    html += `<div class="tree-connector">↓</div>`;
  }
  const suami = find('suami'), istri = find('istri');
  let pasanganRow = '';
  if (suami) pasanganRow += box(suami) + '<span style="margin:0 12px;color:var(--gold);font-size:20px;">⚭</span>';
  pasanganRow += `<div class="tree-node"><div class="tree-node-box mayyit">👤 Pewaris (${jenisMayyit === 'laki' ? 'Almarhum' : 'Almarhumah'})</div></div>`;
  if (istri) pasanganRow += '<span style="margin:0 12px;color:var(--gold);font-size:20px;">⚭</span>' + box(istri);
  html += `<div class="tree-row">${pasanganRow}</div>`;
  const anakL = find('anak-laki'), anakP = find('anak-perempuan');
  if (anakL || anakP) {
    html += `<div class="tree-connector">↓</div>`;
    html += `<div class="tree-row">${anakL ? box(anakL) : ''}${anakP ? box(anakP) : ''}</div>`;
  }
  const cucuL = find('cucu-laki'), cucuP = find('cucu-perempuan');
  if (cucuL || cucuP) {
    html += `<div class="tree-connector">↓</div>`;
    html += `<div class="tree-row">${cucuL ? box(cucuL) : ''}${cucuP ? box(cucuP) : ''}</div>`;
  }
  const sdrL = find('sdr-laki'), sdrP = find('sdr-perempuan'), sdrLA = find('sdr-laki-ayah'), sdrPA = find('sdr-perempuan-ayah');
  if (sdrL || sdrP || sdrLA || sdrPA) {
    html += `<div style="text-align:center;margin:12px 0 4px;font-size:12px;color:var(--text-light);">— Saudara —</div>`;
    html += `<div class="tree-row">${sdrL ? box(sdrL) : ''}${sdrP ? box(sdrP) : ''}${sdrLA ? box(sdrLA) : ''}${sdrPA ? box(sdrPA) : ''}</div>`;
  }

  document.getElementById('family-tree').innerHTML = html;
}

function resetWaris() {
  document.querySelectorAll('#page-waris input[type=number]').forEach(i => i.value = '0');
  document.querySelectorAll('#page-waris select').forEach(i => i.value = '0');
  document.querySelectorAll('#page-waris input[type=checkbox]').forEach(i => i.checked = false);
  document.getElementById('total-harta').value = '';
  document.getElementById('faraidh-result').style.display = 'none';
}


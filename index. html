let activeZakat = 'maal';
function selectZakat(type) {
  activeZakat = type;
  document.querySelectorAll('.zakat-type-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.zakat-form-section').forEach(f => f.classList.remove('active'));
  event.currentTarget.classList.add('active');
  document.getElementById('form-' + type).classList.add('active');
  document.getElementById('zakat-result').style.display = 'none';
}

function showZakatResult(rows, wajib, jumlahZakat, extraNote) {
  let html = rows.map(r => `<div class="result-row ${r.cls||''}">
    <span>${r.label}</span><span>${r.value}</span>
  </div>`).join('');
  
  if (wajib) {
    html += `<div class="result-wajib">
      <div class="rw-label">Zakat yang Wajib Dibayar</div>
      <div class="rw-amount">${fmt(jumlahZakat)}</div>
    </div>`;
  } else {
    html += `<div class="result-tidak-wajib">✅ Belum mencapai nisab, <strong>tidak wajib</strong> zakat saat ini.<br><small style="color:var(--text-light);">Meski begitu, sedekah tetap sangat dianjurkan.</small></div>`;
  }
  if (extraNote) html += `<div style="margin-top:12px;padding:12px;background:var(--green-whisper);border-radius:10px;font-size:13.5px;color:var(--text-mid);line-height:1.7;">${extraNote}</div>`;
  
  document.getElementById('zakat-result-inner').innerHTML = html;
  document.getElementById('zakat-result').style.display = 'block';
  document.getElementById('zakat-result').scrollIntoView({behavior:'smooth'});
}

function hitungZakatMaal() {
  const tunai = getVal('maal-tunai');
  const deposito = getVal('maal-deposito');
  const piutang = getVal('maal-piutang');
  const hargaEmas = getVal('maal-harga-emas') || 1200000;
  const total = tunai + deposito + piutang;
  const nisab = 85 * hargaEmas;
  const wajib = total >= nisab;
  const zakatAmount = total * 0.025;
  showZakatResult([
    {label:'Total Harta', value: fmt(total)},
    {label:'Nisab (85 gr emas)', value: fmt(nisab)},
    {label:'Status Nisab', value: total >= nisab ? '✅ Sudah Mencapai Nisab' : '❌ Belum Mencapai Nisab', cls: total >= nisab ? 'nisab-check' : 'nisab-check tidak'},
    {label:'Kadar Zakat', value:'2,5%'},
    {label:'Zakat Maal (2,5%)', value: fmt(zakatAmount), cls:'total'},
  ], wajib, zakatAmount, 'Zakat maal wajib bila harta tersimpan selama 1 tahun penuh (haul). Pastikan Anda menghitung dari tanggal pertama kali harta mencapai nisab.');
}

function hitungZakatPenghasilan() {
  const bruto = getVal('peng-bruto');
  const lain = getVal('peng-lain');
  const hargaBeras = getVal('peng-harga-beras') || 12000;
  const hargaEmas = getVal('peng-harga-emas') || 1200000;
  const jenisNisab = document.getElementById('peng-nisab-jenis').value;
  const total = bruto + lain;
  
  let nisab = 0;
  let labelNisab = '';
  
  if (jenisNisab === 'pertanian') {
    nisab = 520 * hargaBeras;
    labelNisab = 'Nisab (520 kg beras)';
  } else {
    nisab = (85 * hargaEmas) / 12;
    labelNisab = 'Nisab (85 gr emas / 12 bln)';
  }

  const wajib = total >= nisab;
  const zakatAmount = total * 0.025;
  showZakatResult([
    {label:'Total Penghasilan/Bulan', value: fmt(total)},
    {label:labelNisab, value: fmt(nisab)},
    {label:'Status Nisab', value: total >= nisab ? '✅ Sudah Mencapai Nisab' : '❌ Belum Mencapai Nisab', cls: total >= nisab ? 'nisab-check' : 'nisab-check tidak'},
    {label:'Kadar Zakat', value:'2,5%'},
    {label:'Zakat Penghasilan', value: fmt(zakatAmount), cls:'total'},
    {label:'Zakat Per Tahun', value: fmt(zakatAmount * 12)},
  ], wajib, zakatAmount, 'Zakat penghasilan dikeluarkan setiap bulan saat gaji diterima (pendapat Yusuf Qardawi & mayoritas ulama kontemporer) atau boleh juga dikumpulkan dan dibayar setahun sekali. Jika standar emas, nisab 85 gr dibagi 12 bulan.');
}

function hitungZakatFitrah() {
  const jiwa = getVal('fitrah-jiwa') || 1;
  const hargaBeras = getVal('fitrah-harga-beras') || 15000;
  const berasPerJiwa = 2.5;
  const zakatPerJiwa = berasPerJiwa * hargaBeras;
  const totalZakat = zakatPerJiwa * jiwa;
  showZakatResult([
    {label:'Jumlah Jiwa', value: jiwa + ' orang'},
    {label:'Zakat Per Jiwa', value: berasPerJiwa + ' kg beras = ' + fmt(zakatPerJiwa)},
    {label:'Total Zakat Fitrah', value: fmt(totalZakat), cls:'total'},
    {label:'Dalam Beras', value: (berasPerJiwa * jiwa) + ' kg'},
  ], true, totalZakat, 'Zakat fitrah WAJIB bagi setiap Muslim yang mampu. Dibayar mulai awal Ramadhan hingga sebelum Shalat Idul Fitri. Kepala keluarga menanggung zakat seluruh anggota keluarga yang dinafkahi.');
}

function hitungZakatEmas() {
  const emasGram = getVal('emas-gram');
  const emasHarga = getVal('emas-harga') || 1200000;
  const perakGram = getVal('perak-gram');
  const perakHarga = getVal('perak-harga') || 15000;
  const nilaiEmas = emasGram * emasHarga;
  const nilaiPerak = perakGram * perakHarga;
  const totalNilai = nilaiEmas + nilaiPerak;
  const nisabEmas = 85 * emasHarga;
  const wajib = emasGram >= 85 || perakGram >= 595;
  const zakatAmount = totalNilai * 0.025;
  showZakatResult([
    {label:'Emas: ' + emasGram + ' gr', value: fmt(nilaiEmas)},
    {label:'Perak: ' + perakGram + ' gr', value: fmt(nilaiPerak)},
    {label:'Total Nilai', value: fmt(totalNilai)},
    {label:'Nisab Emas (85 gr)', value: emasGram >= 85 ? '✅ Tercapai ('+emasGram+' gr)' : '❌ Belum ('+emasGram+'/85 gr)', cls: emasGram >= 85 ? 'nisab-check' : 'nisab-check tidak'},
    {label:'Nisab Perak (595 gr)', value: perakGram >= 595 ? '✅ Tercapai' : '❌ Belum', cls: perakGram >= 595 ? 'nisab-check' : 'nisab-check tidak'},
    {label:'Kadar Zakat', value:'2,5%'},
    {label:'Zakat Emas & Perak', value: fmt(zakatAmount), cls:'total'},
  ], wajib, zakatAmount, 'Emas perhiasan yang dipakai sehari-hari: para ulama berbeda pendapat. Mazhab Hanafi & sebagian ulama mewajibkan zakat. Mazhab Syafi\'i berpendapat tidak wajib untuk perhiasan yang dipakai wajar. Untuk keamanan, sebaiknya dikeluarkan zakatnya.');
}

function hitungZakatDagang() {
  const stok = getVal('dag-stok');
  const kas = getVal('dag-kas');
  const piutang = getVal('dag-piutang');
  const hutang = getVal('dag-hutang');
  const hargaEmas = getVal('dag-harga-emas') || 1200000;
  const hartaBersih = stok + kas + piutang - hutang;
  const nisab = 85 * hargaEmas;
  const wajib = hartaBersih >= nisab;
  const zakatAmount = hartaBersih * 0.025;
  showZakatResult([
    {label:'Stok Barang', value: fmt(stok)},
    {label:'Kas & Setara Kas', value: fmt(kas)},
    {label:'Piutang Dagang', value: fmt(piutang)},
    {label:'Hutang Jangka Pendek', value: '(' + fmt(hutang) + ')'},
    {label:'Harta Dagang Bersih', value: fmt(hartaBersih), cls:'total'},
    {label:'Nisab (85 gr emas)', value: fmt(nisab)},

  {term:'Nisab', arabic:'النِّصَاب', kategori:'zakat', definisi:'Batas minimum harta yang mewajibkan zakat. Nisab berbeda-beda: Emas = 85 gram, Perak = 595 gram, Perdagangan = senilai 85 gram emas, Pertanian = 653 kg gabah, Penghasilan = 520 kg beras per bulan.'},
  {term:'Haul', arabic:'الحَوْل', kategori:'zakat', definisi:'Syarat satu tahun penuh kepemilikan harta mencapai nisab sebelum wajib zakat. Berlaku untuk: zakat maal, emas, perak, perdagangan, dan ternak. Tidak berlaku untuk: zakat pertanian (langsung tiap panen) dan zakat fitrah.'},
  {term:'Muzakki', arabic:'المُزَكِّي', kategori:'zakat', definisi:'Orang yang wajib mengeluarkan zakat — Muslim yang merdeka, berakal, baligh, dan hartanya telah memenuhi syarat nisab dan haul.'},
  {term:'Mustahiq', arabic:'المُسْتَحِق', kategori:'zakat', definisi:'8 golongan yang berhak menerima zakat (asnaf tsmaniyah) berdasarkan QS. At-Taubah:60: (1) Fakir, (2) Miskin, (3) Amil (pengelola zakat), (4) Muallaf, (5) Riqab (memerdekakan budak), (6) Gharimin (orang terlilit hutang), (7) Fi sabilillah, (8) Ibnu sabil (musafir yang kehabisan bekal).'},
  {term:'Zakat Maal', arabic:'زَكَاة المَال', kategori:'zakat', definisi:'Zakat atas harta simpanan yang telah mencapai nisab dan haul. Meliputi: uang tunai, tabungan, deposito, piutang yang bisa ditagih, emas/perak, dan aset yang tidak digunakan. Kadar: 2,5%.'},
  {term:'Zakat Fitrah', arabic:'زَكَاة الفِطْر', kategori:'zakat', definisi:'Zakat yang wajib dikeluarkan oleh setiap Muslim di bulan Ramadhan hingga sebelum Shalat Idul Fitri. Besarnya 1 sha\' (± 2,5 kg) bahan makanan pokok atau nilainya. Tujuan: menyucikan diri dan membahagiakan fakir miskin di hari raya.'},
  {term:'Zakat Penghasilan (Profesi)', arabic:'زَكَاة الرَّاتِب', kategori:'zakat', definisi:'Zakat dari penghasilan profesi modern seperti gaji, honorarium, dll. Nisab = 520 kg beras per bulan. Kadar 2,5% dari bruto. Dikeluarkan tiap bulan atau dikumpulkan setahun lalu dibayar sekaligus. Landasan: QS. Al-Baqarah:267 dan ijtihad ulama kontemporer.'},
  {term:'Zakat Tijarah (Perdagangan)', arabic:'زَكَاة التِّجَارَة', kategori:'zakat', definisi:'Zakat atas harta yang diperdagangkan. Dihitung dari: Stok Barang + Kas + Piutang − Hutang Jangka Pendek. Syarat nisab = 85 gram emas. Kadar: 2,5%. Dihitung tiap tahun (haul).'},
  {term:'Zakat Zira\'ah (Pertanian)', arabic:'زَكَاة الزِّرَاعَة', kategori:'zakat', definisi:'Zakat hasil pertanian. Nisab: 653 kg gabah (5 wasaq). Kadar: 10% jika tadah hujan, 5% jika menggunakan irigasi/biaya. Tidak ada syarat haul — dikeluarkan langsung setiap panen.'},
  {term:'Amil Zakat', arabic:'عَامِل الزَّكَاة', kategori:'zakat', definisi:'Orang atau lembaga yang bertugas mengumpulkan, mengelola, dan mendistribusikan zakat. Termasuk salah satu dari 8 golongan mustahiq yang berhak mendapat bagian dari zakat. Di Indonesia direpresentasikan oleh BAZNAS dan LAZ resmi.'},
  {term:'Infak & Sedekah', arabic:'الإِنْفَاق وَالصَّدَقَة', kategori:'zakat', definisi:'Berbeda dari zakat: infak dan sedekah bersifat sunnah (tidak wajib) dan tidak terikat nisab/haul. Sedekah bisa diberikan kepada siapa saja, tidak hanya 8 asnaf. Keduanya sangat dianjurkan bahkan bagi yang belum mencapai nisab zakat.'},
];

function renderGlosarium(data) {
  let html = '';
  if (data.length === 0) {
    html = '<div style="text-align:center;padding:40px;color:var(--text-light);">Tidak ditemukan istilah yang sesuai.</div>';
  }
  data.forEach((item, i) => {
    const badgeHTML = item.badge ? `<span class="badge ${item.badge}">${item.badge.toUpperCase()}</span>` : '';
    html += `<div class="glos-item" id="glos-${i}">
      <div class="glos-header" onclick="toggleGlos(${i})">
        <div>
          <span class="glos-term">${item.term}</span>
          <span class="glos-arabic">${item.arabic}</span>
          ${badgeHTML}
        </div>
        <span class="glos-chevron">▼</span>
      </div>
      <div class="glos-body">
        <span class="glos-tag ${item.kategori}">${item.kategori === 'waris' ? '⚖️ Faraidh/Waris' : '🌙 Zakat'}</span>
        <div>${item.definisi}</div>
      </div>
    </div>`;
  });
  document.getElementById('glos-container').innerHTML = html;
}

function toggleGlos(i) {
  const el = document.getElementById('glos-' + i);
  el.classList.toggle('open');
}

let activeTab = 'semua';
function filterTab(tab) {
  activeTab = tab;
  document.querySelectorAll('.glos-tab').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');
  filterGlosarium();
}

function filterGlosarium() {
  const q = (document.getElementById('glos-search').value || '').toLowerCase();
  let filtered = glosData;
  if (activeTab !== 'semua') filtered = filtered.filter(g => g.kategori === activeTab);
  if (q) filtered = filtered.filter(g => g.term.toLowerCase().includes(q) || g.definisi.toLowerCase().includes(q) || g.arabic.includes(q));
  renderGlosarium(filtered);
}

// Init
renderGlosarium(glosData);
</script>

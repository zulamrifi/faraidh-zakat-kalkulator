    {label:'Zakat Perdagangan (2,5%)', value: fmt(zakatAmount), cls:'total'},
  ], wajib, zakatAmount, 'Zakat perdagangan dihitung saat haul (genap 1 tahun). Hutang yang diperhitungkan hanya hutang jangka pendek yang jatuh tempo dalam tahun berjalan.');
}

function hitungZakatTani() {
  const hasil = getVal('tani-hasil');
  const pengairan = document.getElementById('tani-pengairan').value;
  const hargaGabah = getVal('tani-harga') || 5000;
  const nisabKg = 653;
  const wajib = hasil >= nisabKg;
  const kadar = pengairan === 'hujan' ? 0.10 : 0.05;
  const zakatKg = hasil * kadar;
  const zakatRp = zakatKg * hargaGabah;

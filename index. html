<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mirath & Zakat — Kalkulator Islam</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Noto+Nastaliq+Urdu:wght@400;600&family=Source+Serif+4:opsz,wght@8..60,300;8..60,400;8..60,500&display=swap" rel="stylesheet">
<style>
:root {
  --green-deep: #1a3a2a;
  --green-rich: #2d5a3d;
  --green-mid: #3d7a52;
  --green-light: #5a9e6f;
  --green-pale: #8ec9a0;
  --green-mist: #c8e6d0;
  --green-whisper: #eaf5ed;
  --gold: #c9a227;
  --gold-light: #e8c55a;
  --gold-pale: #f5e8b8;
  --ivory: #faf8f2;
  --text-dark: #1a2e22;
  --text-mid: #3a5244;
  --text-light: #6b8c78;
  --shadow: rgba(26,58,42,0.15);
  --border: rgba(61,122,82,0.2);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Source Serif 4', Georgia, serif;
  background: var(--ivory);
  color: var(--text-dark);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ============ HEADER ============ */
header {
  background: linear-gradient(135deg, var(--green-deep) 0%, var(--green-rich) 60%, var(--green-mid) 100%);
  padding: 0;
  position: relative;
  overflow: hidden;
}
header::before {
  content: '';
  position: absolute; inset: 0;
  background-image: 
    radial-gradient(circle at 20% 50%, rgba(201,162,39,0.08) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(201,162,39,0.06) 0%, transparent 40%);
}
.header-pattern {
  position: absolute; inset: 0; opacity: 0.04;
  background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M30 0 L35 10 L45 10 L37 16 L40 27 L30 21 L20 27 L23 16 L15 10 L25 10 Z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
}
.header-inner {
  position: relative; z-index: 1;
  text-align: center;
  padding: 48px 24px 40px;
}
.header-bismillah {
  font-family: 'Noto Nastaliq Urdu', serif;
  font-size: clamp(22px, 5vw, 32px);
  color: var(--gold-light);
  letter-spacing: 2px;
  margin-bottom: 12px;
  opacity: 0.9;
}
.header-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(28px, 6vw, 52px);
  color: var(--ivory);
  font-weight: 700;
  line-height: 1.15;
  margin-bottom: 8px;
}
.header-title span { color: var(--gold-light); }
.header-sub {
  font-size: clamp(13px, 2.5vw, 16px);
  color: var(--green-mist);
  letter-spacing: 0.5px;
  opacity: 0.85;
  margin-bottom: 32px;
}
.header-ornament {
  display: flex; align-items: center; justify-content: center; gap: 16px;
  margin-bottom: 28px;
}
.ornament-line { width: 80px; height: 1px; background: linear-gradient(to right, transparent, var(--gold)); }
.ornament-line.r { background: linear-gradient(to left, transparent, var(--gold)); }
.ornament-star { color: var(--gold); font-size: 18px; }

/* ============ NAV ============ */
nav {
  background: var(--green-deep);
  border-bottom: 2px solid var(--gold);
  position: sticky; top: 0; z-index: 100;
  box-shadow: 0 4px 20px var(--shadow);
}
.nav-inner {
  display: flex; justify-content: center; flex-wrap: wrap;
  max-width: 900px; margin: 0 auto;
}
.nav-btn {
  background: none; border: none; cursor: pointer;
  color: var(--green-mist);
  font-family: 'Source Serif 4', serif;
  font-size: 14px; font-weight: 500;
  padding: 16px 28px;
  letter-spacing: 0.3px;
  position: relative;
  transition: color 0.25s;
}
.nav-btn::after {
  content: ''; position: absolute; bottom: 0; left: 50%; right: 50%;
  height: 2px; background: var(--gold);
  transition: left 0.25s, right 0.25s;
}
.nav-btn:hover, .nav-btn.active { color: var(--gold-light); }
.nav-btn.active::after, .nav-btn:hover::after { left: 16px; right: 16px; }

/* ============ MAIN ============ */
main { max-width: 1000px; margin: 0 auto; padding: 40px 16px 80px; }
.page { display: none; }
.page.active { display: block; animation: fadeUp 0.4s ease; }
@keyframes fadeUp { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }

/* ============ SECTION TITLE ============ */
.section-header {
  text-align: center; margin-bottom: 36px;
}
.section-header h2 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(22px, 4vw, 32px);
  color: var(--green-deep);
  margin-bottom: 8px;
}
.section-header p { color: var(--text-light); font-size: 15px; }
.divider {
  display: flex; align-items: center; gap: 12px;
  margin: 12px auto; max-width: 300px;
}
.divider-line { flex: 1; height: 1px; background: var(--green-pale); }
.divider-gem { color: var(--gold); font-size: 14px; }

/* ============ CARD ============ */
.card {
  background: white;
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 28px;
  margin-bottom: 24px;
  box-shadow: 0 2px 12px var(--shadow);
}
.card-title {
  font-family: 'Playfair Display', serif;
  font-size: 18px; color: var(--green-deep);
  margin-bottom: 16px;
  display: flex; align-items: center; gap: 10px;
}
.card-title .icon {
  width: 32px; height: 32px; border-radius: 8px;
  background: var(--green-whisper);
  display: flex; align-items: center; justify-content: center;
  font-size: 16px;
  border: 1px solid var(--green-mist);
}

/* ============ FORM ============ */
.form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
@media(max-width:600px) { .form-grid { grid-template-columns: 1fr; } }

label { display: block; font-size: 13px; color: var(--text-mid); margin-bottom: 5px; font-weight: 500; }
input[type=number], select {
  width: 100%;
  padding: 11px 14px;
  border: 1.5px solid var(--border);
  border-radius: 10px;
  font-family: 'Source Serif 4', serif;
  font-size: 15px;
  color: var(--text-dark);
  background: var(--green-whisper);
  transition: border-color 0.2s, box-shadow 0.2s;
  -webkit-appearance: none;
}
input[type=number]:focus, select:focus {
  outline: none;
  border-color: var(--green-mid);
  box-shadow: 0 0 0 3px rgba(61,122,82,0.12);
}

.checkbox-group { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 4px; }
.checkbox-item {
  display: flex; align-items: center; gap: 8px;
  background: var(--green-whisper);
  border: 1.5px solid var(--border);
  border-radius: 8px;
  padding: 8px 14px;
  cursor: pointer;
  transition: all 0.2s;
  font-size: 14px;
}
.checkbox-item:hover { border-color: var(--green-mid); background: var(--green-mist); }
.checkbox-item input { accent-color: var(--green-rich); }
.checkbox-item.checked { border-color: var(--green-mid); background: var(--green-mist); }

/* ============ BTN ============ */
.btn-primary {
  background: linear-gradient(135deg, var(--green-rich), var(--green-mid));
  color: white; border: none; cursor: pointer;
  font-family: 'Source Serif 4', serif;
  font-size: 15px; font-weight: 500;
  padding: 14px 36px; border-radius: 12px;
  letter-spacing: 0.3px;
  box-shadow: 0 4px 16px rgba(45,90,61,0.3);
  transition: transform 0.15s, box-shadow 0.15s;
  display: block; width: 100%; margin-top: 20px;
}
.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(45,90,61,0.4); }
.btn-primary:active { transform: translateY(0); }

.btn-reset {
  background: none; border: 1.5px solid var(--border);
  color: var(--text-light); cursor: pointer;
  font-size: 13px; padding: 10px 20px; border-radius: 10px;
  margin-top: 10px; width: 100%;
  transition: all 0.2s;
}
.btn-reset:hover { border-color: var(--green-mid); color: var(--green-mid); }

/* ============ RESULT ============ */
#faraidh-result, #zakat-result { display: none; }

.result-box {
  background: linear-gradient(135deg, var(--green-deep), var(--green-rich));
  border-radius: 16px; padding: 28px;
  color: white; margin-bottom: 20px;
  position: relative; overflow: hidden;
}
.result-box::before {
  content: ''; position: absolute; top: -30px; right: -30px;
  width: 150px; height: 150px; border-radius: 50%;
  background: rgba(255,255,255,0.04);
}
.result-title {
  font-family: 'Playfair Display', serif;
  font-size: 20px; color: var(--gold-light);
  margin-bottom: 6px;
}
.result-harta-pokok {
  font-size: 28px; font-weight: 600;
  color: white; margin-bottom: 4px;
}
.result-sub { font-size: 13px; color: var(--green-pale); }

.ahli-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px,1fr)); gap: 12px; margin-top: 16px; }
.ahli-card {
  background: white; border-radius: 12px; padding: 16px;
  border-left: 4px solid var(--green-mid);
  box-shadow: 0 2px 8px var(--shadow);
}
.ahli-card.mendapat { border-left-color: var(--green-mid); }
.ahli-card.hajb { border-left-color: #e0a0a0; background: #fff8f8; }
.ahli-name { font-weight: 600; font-size: 15px; color: var(--green-deep); margin-bottom: 4px; }
.ahli-bagian { font-size: 20px; font-weight: 700; color: var(--green-rich); }
.ahli-nominal { font-size: 13px; color: var(--text-light); }
.ahli-status { font-size: 12px; color: #c06060; }
.ahli-alasan { font-size: 12px; color: var(--text-light); margin-top: 4px; font-style: italic; }

.info-box {
  border-radius: 12px; padding: 16px 20px; margin-bottom: 12px;
  border-left: 4px solid;
  font-size: 14px; line-height: 1.6;
}
.info-box.aul { background: #fff9e6; border-color: #e8c55a; color: #7a6020; }
.info-box.radd { background: #e8f5ff; border-color: #5aa0e8; color: #204060; }
.info-box.ummariyatayn { background: #f0f5ff; border-color: #8098e0; color: #2a3570; }
.info-box strong { display: block; margin-bottom: 4px; font-size: 15px; }

/* ============ DIAGRAM ============ */
.diagram-container {
  background: white; border-radius: 16px;
  border: 1px solid var(--border);
  padding: 24px; margin-bottom: 24px;
  overflow-x: auto;
}
.diagram-title {
  font-family: 'Playfair Display', serif;
  font-size: 17px; color: var(--green-deep);
  margin-bottom: 16px; text-align: center;
}
#family-tree {
  display: flex; flex-direction: column; align-items: center; gap: 16px;
  min-width: 320px;
}
.tree-row { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; align-items: center; }
.tree-node {
  display: flex; flex-direction: column; align-items: center;
  gap: 4px;
}
.tree-node-box {
  padding: 8px 14px; border-radius: 10px;
  font-size: 13px; font-weight: 600; text-align: center;
  min-width: 90px; position: relative;
}
.tree-node-box.mendapat {
  background: var(--green-mist); border: 2px solid var(--green-mid);
  color: var(--green-deep);
}
.tree-node-box.hajb {
  background: #ffe8e8; border: 2px dashed #e08080;
  color: #906060; text-decoration: line-through;
}
.tree-node-box.mayyit {
  background: var(--green-deep); border: 2px solid var(--gold);
  color: white; font-size: 14px;
}
.tree-node-bagian {
  font-size: 13px; font-weight: 700; color: var(--green-rich);
}
.tree-node-hajb-text { font-size: 11px; color: #c06060; }

.tree-connector {
  display: flex; justify-content: center;
  color: var(--green-pale); font-size: 20px;
  line-height: 1;
}

/* ============ ZAKAT ============ */
.zakat-type-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px,1fr)); gap: 10px; margin-bottom: 24px; }
.zakat-type-btn {
  background: var(--green-whisper); border: 2px solid var(--border);
  border-radius: 12px; padding: 14px 10px; text-align: center;
  cursor: pointer; transition: all 0.2s;
  font-family: 'Source Serif 4', serif;
}
.zakat-type-btn .zt-icon { font-size: 22px; margin-bottom: 6px; }
.zakat-type-btn .zt-name { font-size: 13px; color: var(--text-dark); font-weight: 500; }
.zakat-type-btn:hover, .zakat-type-btn.active {
  border-color: var(--green-mid);
  background: var(--green-mist);
}
.zakat-type-btn.active { border-color: var(--green-rich); }

.zakat-form-section { display: none; }
.zakat-form-section.active { display: block; animation: fadeUp 0.3s ease; }

.result-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 12px 0; border-bottom: 1px solid var(--border);
  font-size: 15px;
}
.result-row:last-child { border-bottom: none; }
.result-row span:first-child { color: var(--text-mid); }
.result-row span:last-child { font-weight: 600; color: var(--green-deep); }
.result-row.total span { font-size: 18px; color: var(--green-rich); }
.result-row.nisab-check span:last-child { color: green; }
.result-row.nisab-check.tidak span:last-child { color: #c06060; }
.result-wajib {
  background: linear-gradient(135deg, var(--gold), var(--gold-light));
  color: var(--green-deep); border-radius: 12px;
  padding: 20px; text-align: center; margin-top: 16px;
}
.result-wajib .rw-label { font-size: 14px; margin-bottom: 4px; }
.result-wajib .rw-amount { font-size: 28px; font-weight: 700; }
.result-tidak-wajib {
  background: var(--green-whisper); border-radius: 12px;
  padding: 16px; text-align: center; margin-top: 16px;
  color: var(--text-mid); font-size: 15px;
}

/* ============ GLOSARIUM ============ */
.search-box {
  position: relative; margin-bottom: 24px;
}
.search-box input {
  padding-left: 42px; background: white;
  border: 1.5px solid var(--border);
}
.search-box::before {
  content: '🔍'; position: absolute;
  left: 14px; top: 50%; transform: translateY(-50%);
  font-size: 16px; pointer-events: none;
}
.glos-tabs { display: flex; gap: 8px; margin-bottom: 24px; flex-wrap: wrap; }
.glos-tab {
  padding: 8px 20px; border-radius: 20px;
  font-size: 14px; cursor: pointer; border: none;
  font-family: 'Source Serif 4', serif;
  background: var(--green-whisper); color: var(--text-mid);
  border: 1.5px solid var(--border);
  transition: all 0.2s;
}
.glos-tab.active, .glos-tab:hover {
  background: var(--green-rich); color: white; border-color: var(--green-rich);
}

.glos-item {
  background: white; border-radius: 12px;
  border: 1px solid var(--border);
  margin-bottom: 12px;
  overflow: hidden;
  transition: box-shadow 0.2s;
}
.glos-item:hover { box-shadow: 0 4px 16px var(--shadow); }
.glos-header {
  padding: 16px 20px; cursor: pointer;
  display: flex; justify-content: space-between; align-items: center;
}
.glos-term { font-family: 'Playfair Display', serif; font-size: 17px; color: var(--green-deep); }
.glos-arabic { font-size: 18px; color: var(--gold); margin-left: 10px; }
.glos-chevron { color: var(--green-light); transition: transform 0.25s; font-size: 13px; }
.glos-item.open .glos-chevron { transform: rotate(180deg); }
.glos-body {
  display: none; padding: 0 20px 18px;
  font-size: 14.5px; line-height: 1.7; color: var(--text-mid);
  border-top: 1px solid var(--border);
  padding-top: 14px;
}
.glos-item.open .glos-body { display: block; }
.glos-tag {
  display: inline-block; font-size: 11px;
  padding: 2px 10px; border-radius: 20px; margin-bottom: 8px;
  font-weight: 600; letter-spacing: 0.3px;
}
.glos-tag.waris { background: var(--green-mist); color: var(--green-rich); }
.glos-tag.zakat { background: var(--gold-pale); color: #7a6020; }

/* ============ FOOTER ============ */
footer {
  background: var(--green-deep); color: var(--green-pale);
  text-align: center; padding: 28px 16px;
  font-size: 13px; line-height: 1.8;
  border-top: 2px solid var(--gold);
}
footer .footer-quote {
  font-family: 'Playfair Display', serif;
  font-size: 15px; color: var(--gold-light);
  font-style: italic; margin-bottom: 8px;
}

/* ============ BADGE ============ */
.badge {
  display: inline-block; font-size: 11px;
  padding: 3px 10px; border-radius: 20px;
  font-weight: 600; margin-left: 6px;
  vertical-align: middle;
}
.badge.aul { background: #fff0b0; color: #7a6020; }
.badge.radd { background: #d0eeff; color: #204a7a; }
.badge.ummariyatayn { background: #e0e8ff; color: #2a3870; }

/* RESPONSIVE */
@media(max-width:480px) {
  .nav-btn { padding: 13px 16px; font-size: 13px; }
  .card { padding: 20px; }
  .result-box { padding: 20px; }
  .ahli-grid { grid-template-columns: 1fr 1fr; }
}
</style>
</head>
<body>

<header>
  <div class="header-pattern"></div>
  <div class="header-inner">
    <div class="header-bismillah">بِسْمِ اللهِ الرَّحْمٰنِ الرَّحِيْمِ</div>
    <div class="header-ornament">
      <div class="ornament-line"></div>
      <div class="ornament-star">✦</div>
      <div class="ornament-line r"></div>
    </div>
    <h1 class="header-title">Mirath & <span>Zakat</span></h1>
    <div class="header-sub">Kalkulator Faraidh & Zakat Islam · Edukasi Hukum Waris & Zakat<br><strong style="color: var(--gold-light); font-size: 15px; margin-top: 6px; display: inline-block;">Penyuluh Agama KUA Kecamatan Sekongkang</strong></div>
  </div>
</header>

<nav>
  <div class="nav-inner">
    <button class="nav-btn active" onclick="showPage('waris')">⚖️ Kalkulator Waris</button>
    <button class="nav-btn" onclick="showPage('zakat')">🌙 Kalkulator Zakat</button>
    <button class="nav-btn" onclick="showPage('glosarium')">📖 Glosarium</button>
  </div>
</nav>

<main>

<div id="page-waris" class="page active">
  <div class="section-header">
    <h2>Kalkulator Faraidh</h2>
    <div class="divider"><div class="divider-line"></div><div class="divider-gem">✦</div><div class="divider-line"></div></div>
    <p>Hitung pembagian warisan sesuai syariat Islam (Al-Quran, Hadits, dan Ijma' Ulama)</p>
  </div>

  <div class="card">
    <div class="card-title"><div class="icon">💰</div> Harta Peninggalan</div>
    <div class="form-grid">
      <div>
        <label>Jumlah Harta Warisan (Rp)</label>
        <input type="number" id="total-harta" placeholder="Contoh: 100000000" min="0">
      </div>
      <div>
        <label>Hutang Almarhum (Rp)</label>
        <input type="number" id="hutang" placeholder="0" min="0" value="0">
      </div>
      <div>
        <label>Wasiat (maks. 1/3 harta bersih) (Rp)</label>
        <input type="number" id="wasiat" placeholder="0" min="0" value="0">
      </div>
      <div>
        <label>Biaya Pemakaman (Rp)</label>
        <input type="number" id="biaya-pemakaman" placeholder="0" min="0" value="0">
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-title"><div class="icon">👤</div> Almarhum/Almarhumah</div>
    <div class="form-grid">
      <div>
        <label>Jenis Kelamin Almarhum</label>
        <select id="jenis-mayyit">
          <option value="laki">Laki-laki</option>
          <option value="perempuan">Perempuan</option>
        </select>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-title"><div class="icon">👨‍👩‍👧</div> Ahli Waris yang Ditinggalkan</div>
    <p style="font-size:13px;color:var(--text-light);margin-bottom:14px;">Pilih ahli waris yang <strong>masih hidup</strong> saat pewaris meninggal.</p>

    <div style="margin-bottom:18px;">
      <label style="font-size:14px;color:var(--green-deep);font-weight:600;margin-bottom:10px;display:block;">▸ Pasangan</label>
      <div class="checkbox-group" id="group-pasangan" style="align-items: center;">
        <label class="checkbox-item"><input type="checkbox" id="suami"> Suami</label>
        <div style="display:flex; align-items:center; gap:8px; background:var(--green-whisper); padding:8px 14px; border-radius:8px; border:1.5px solid var(--border);">
          <label style="margin:0; font-size:14px; cursor:pointer;">Jumlah Istri:</label>
          <select id="istri" style="padding:4px; border-radius:6px; width:60px; font-size:14px;">
            <option value="0">0</option><option value="1">1</option><option value="2">2</option><option value="3">3</option><option value="4">4</option>
          </select>
        </div>
      </div>
    </div>

    <div style="margin-bottom:18px;">
      <label style="font-size:14px;color:var(--green-deep);font-weight:600;margin-bottom:10px;display:block;">▸ Anak</label>
      <div class="form-grid">
        <div>
